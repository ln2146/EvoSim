{
    "num_users": 3,
    "num_time_steps": 5,
    "agent_config_generation": "file",
    "agent_config_path": "separate",
    "max_total_posts": 10000,
    "max_total_users": 10,
    "separate_personas": {
        "neutral_file": "personas/neutral_personas_database.json"
    },
    "temperature": 0.9,
    "reset_db": true,
    "initial_follow_probability": 0.1,
    "new_users": {
        "add_probability": 1.0,
        "follow_probability": 0.2,
        "users_per_step": 0,
        "start_step": 1
    },
    "news_injection": {
        "start_step": 0,
        "articles_per_injection": 10
    },
    "moderation": {
        "content_moderation": false,
        "flag_threshold": 5,
        "note_threshold": 3
    },
    "feed": {
        "total_news_posts": 8
    },
    "generate_own_post": true,
    "experiment": {
        "type": "no_fact_checking",
        "settings": {}
    },
    "opinion_balance_system": {
        "enabled": false,
        "monitoring_enabled": false,
        "intervention_threshold": 1,
        "feedback_system_enabled": true,
        "trending_posts_scan_interval": 3,
        "feedback_monitoring_interval": 1,
        "feedback_monitoring_cycles": 2,
        "standalone_mode": true
    },
    "malicious_bot_system": {
        "enabled": false,
        "cluster_size": 15,
        "attack_probability": 1.0,
        "target_post_types": [
            "user_post"
        ]
    },
    "prebunking_system": {
        "enabled": false
    },
    "recommender": {
        "enabled": true,
        "scoring": {
            "w_likes": 1.0,
            "w_shares": 2.0,
            "w_comments": 1.0
        },
        "freshness": {
            "decay_rate": 0.1,
            "min_freshness": 0.1,
            "bias": 180
        },
        "diversity": {
            "enabled": true,
            "penalty_factor": 0.7,
            "max_same_author": 3
        },
        "embedding": {
            "enabled": true,
            "model_name": "paraphrase-MiniLM-L6-v2",
            "use_openai_embedding": false,
            "cache_embeddings": true,
            "embedding_weight": 0.3,
            "max_cache_size": 10000
        },
        "source": {
            "in_network_ratio": 0.5,
            "out_network_ratio": 0.5,
            "max_candidates_per_source": 100
        },
        "oon": {
            "enabled": true,
            "boost_factor": 1.0,
            "high_engagement_threshold": 50
        },
        "filter": {
            "filter_taken_down": true,
            "filter_blocked_authors": true,
            "filter_self_posts": true,
            "filter_seen_posts": false,
            "min_content_length": 0
        },
        "author_credibility": {
            "enabled": true,
            "high_credibility_threshold": 0.7,
            "low_credibility_threshold": 0.3,
            "high_credibility_boost": 1.15,
            "low_credibility_penalty": 0.75,
            "default_influence_score": 0.5,
            "max_boost_factor": 1.3,
            "min_penalty_factor": 0.5
        },
        "selection": {
            "news_top_k": 10,
            "news_pick_n": 5,
            "news_secondary_offset": 10,
            "news_secondary_top_k": 10,
            "news_secondary_pick_n": 3,
            "negative_news_pick_n": 1,
            "non_news_top_k": 10,
            "non_news_pick_n": 2,
            "include_ties": true
        }
    }
}